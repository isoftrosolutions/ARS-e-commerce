# ARS eCommerce Environment Configuration
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES

# Database Configuration
DB_HOST=localhost
DB_NAME=ars_ecommerce
DB_USER=root
DB_PASSWORD=

# SMTP/Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=easyshoppinga.r.s1@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_EMAIL=easyshoppinga.r.s1@gmail.com
SMTP_FROM_NAME=ARS Store

# Site Configuration
SITE_NAME=ARS Shop
SITE_URL=http://localhost/ARS
CURRENCY=Rs.

# Upload Configuration
UPLOAD_DIR=uploads/
MAX_FILE_SIZE=2097152

# Security
SESSION_LIFETIME=7200
CSRF_TOKEN_LIFETIME=3600
RATE_LIMIT_ATTEMPTS=5
RATE_LIMIT_LOCKOUT=600

# Shipping
FREE_SHIPPING_THRESHOLD=1000
SHIPPING_FEE=150
